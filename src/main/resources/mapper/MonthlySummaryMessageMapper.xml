<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ttokttak.dao.MonthlySummaryMessageDao">

    <select id="findAll" resultType="MonthlySummaryMessage">
        SELECT id, cid, message
        FROM MONTHLY_SUMMARY_MESSAGE
        ORDER BY cid
    </select>

</mapper>