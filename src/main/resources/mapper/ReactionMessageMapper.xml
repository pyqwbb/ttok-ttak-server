<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ttokttak.dao.ReactionMessageDao">

    <select id="findAll" resultType="ReactionMessage">
        SELECT id, cid, goal_count, message
        FROM REACTION_MESSAGE
        ORDER BY cid, goal_count
    </select>

</mapper>